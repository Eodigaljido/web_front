# --- 앱(Expo) → share-web 매핑 ---
# EXPO_PUBLIC_API_BASE_URL         → VITE_API_BASE_URL (슬래시 없이)
# EXPO_PUBLIC_SHARE_BASE_URL       → VITE_SHARE_SITE_URL
# EXPO_PUBLIC_KAKAO_REST_API_KEY   → VITE_KAKAO_REST_API_KEY (+ EC2 Nginx KakaoAK)
# EXPO_PUBLIC_GOOGLE_MAPS_*        → (미사용, 웹은 카카오맵)
# EXPO_PUBLIC_TMAP_APP_KEY         → (미사용)
# EXPO_PUBLIC_WEATHER_API_KEY      → (미사용)
# 지도 타일용: 카카오 콘솔「JavaScript」키 → VITE_KAKAO_MAP_APP_KEY (앱 .env에 없음)

VITE_API_BASE_URL=
VITE_SHARE_SITE_URL=https://eodigaljido.uk
VITE_APP_SCHEME=eodigaljido
VITE_PLAY_STORE_URL=https://play.google.com/store/apps/details?id=com.eodigaljido.app
VITE_APP_STORE_URL=
VITE_OG_IMAGE_URL=https://eodigaljido.uk/og-default.png

VITE_KAKAO_MAP_APP_KEY=
VITE_KAKAO_REST_API_KEY=
